Property.CMakeOutputPath_libuv "@('../..'->MakeAbsolute())"
%Target Lib_cmlibuv
{
	Target.CLanguage GNU11
	Compile
	{
		!!Compile.Type C
		SearchPath "@('../../Utilities'->MakeAbsolute());@('../../../../../../External/CMake/Utilities'->MakeAbsolute());@('../../../../../../External/CMake/Utilities/cmlibuv/include'->MakeAbsolute());@('../../../../../../External/CMake/Utilities/cmlibuv/src'->MakeAbsolute());@('../../../../../../External/CMake/Utilities/cmlibuv/src/unix'->MakeAbsolute());@('../../Source'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "LIBARCHIVE_STATIC;NDEBUG;_DARWIN_UNLIMITED_SELECT=1;_DARWIN_USE_64_BIT_INODE=1;@(Compile.PreprocessorDefines)"
		CLanguage GNU11
	}
	Property.MalterlibTargetNameType Normal
	Target.Group "External/libuv"
	Target.Type StaticLibrary
	Target.BaseName cmlibuv
	%Group Utilities
	{
		%Group src
		{
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/fs-poll.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/heap-inl.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/idna.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/idna.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/inet.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/queue.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/strscpy.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/strscpy.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/threadpool.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/timer.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/uv-common.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/uv-common.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/uv-data-getter-setters.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibuv/src/version.c"
			{
				Compile.Type C
			}
			%Group unix
			{
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/async.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/atomic-ops.h"
				{
					Compile.Type None
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/core.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/dl.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/fs.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/getaddrinfo.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/getnameinfo.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/internal.h"
				{
					Compile.Type None
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/loop-watcher.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/loop.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/pipe.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/poll.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/process.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/signal.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/spinlock.h"
				{
					Compile.Type None
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/stream.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/tcp.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/thread.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/tty.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/udp.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/bsd-ifaddrs.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/darwin.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/darwin-proctitle.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/fsevents.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/kqueue.c"
				{
					Compile.Type C
				}
				%File "../../../../../../External/CMake/Utilities/cmlibuv/src/unix/proctitle.c"
				{
					Compile.Type C
				}
			}
		}
	}
}
