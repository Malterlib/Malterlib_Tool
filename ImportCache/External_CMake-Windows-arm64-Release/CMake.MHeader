%Target "Com_CMake_cmcldeps"
{
	Compile
	{
		!!Compile.Type "WindowsResource"
		SearchPath += [
			`@('.'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('.'->MakeAbsolute())/Source`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Source`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Source/LexerParser`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities/std`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/curl/include`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/zlib`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"LIBARCHIVE_STATIC",
			"UNICODE",
			"WIN32_LEAN_AND_MEAN",
			"_CRT_NONSTDC_NO_DEPRECATE",
			"_CRT_SECURE_NO_DEPRECATE",
			"_UNICODE"
		]
	}
	Compile
	{
		!!Compile.Type "C++"
		SearchPath += [
			`@('.'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('.'->MakeAbsolute())/Source`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Source`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Source/LexerParser`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities/std`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/curl/include`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/zlib`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"LIBARCHIVE_STATIC",
			"UNICODE",
			"WIN32_LEAN_AND_MEAN",
			"_CRT_NONSTDC_NO_DEPRECATE",
			"_CRT_SECURE_NO_DEPRECATE",
			"_UNICODE"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/CMake"
	{
		!!Target.Group undefined
	}
	Target.Type "ConsoleExecutable"
	Target.BaseName "CMake_cmcldeps"
	Target.BaseFileName "cmcldeps"
	%Group "Source"
	{
		%File `@('../../../../External/CMake'->MakeAbsolute())/Source/cmcldeps.cxx`
		{
			Compile.Type "C++"
		}
		%File `@('../../../../External/CMake'->MakeAbsolute())/Source/cmake.version.manifest`
		{
			Compile.Disabled true
		}
	}
	%Dependency "Lib_CMake_CMakeLib"
	%Dependency "Lib_CMake_CMakeVersion"
	%Dependency "Lib_bzip2_cmbzip2"
	%Dependency "Lib_CMake_cmcppdap"
	%Dependency "Lib_CMake_cmexpat"
	%Dependency "Lib_JsonCpp_cmjsoncpp"
	%Dependency "Lib_libarchive_cmlibarchive"
	%Dependency "Lib_CMLIBLZMA_cmliblzma"
	%Dependency "Lib_librhash_cmlibrhash"
	%Dependency "Lib_libuv_cmlibuv"
	%Dependency "Lib_CMake_cmstd"
	%Dependency "Lib_cmsys_cmsys"
	%Dependency "Lib_zstd_cmzstd"
}
%Target "Lib_CMake_CTestLib"
{
	Compile
	{
		!!Compile.Type "C++"
		SearchPath += [
			`@('.'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
