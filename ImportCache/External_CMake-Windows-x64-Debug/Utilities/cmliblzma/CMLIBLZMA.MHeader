					}
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/common/filter_common.c`
					{
						Compile.Type "C"
					}
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/common/filter_decoder.c`
					{
