	%Group "Windows"
	{
		%Group "x86"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "Utilities"
				{
					%Group "cmcurl"
					{
						%Group "lib"
						{
							%File `@('../..'->MakeAbsolute())/Utilities/cmcurl/lib/curl_config.h`
							{
								Compile.Disabled true
							}
						}
					}
				}
			}
		}
	}
	%Dependency "Lib_CMake_cmnghttp2"
	{
		Dependency.Indirect true
	}
	%Dependency "Lib_CMZLIB_cmzlib"
	{
