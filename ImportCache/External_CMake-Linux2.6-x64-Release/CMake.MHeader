%Target "Lib_cmsys"
{
	Compile
	{
		!!Compile.Type "C++"
		SearchPath += [
			"Source"->MakeAbsolute(),
			"Source/kwsys"->MakeAbsolute()
		]
		PreprocessorDefines += [
			"KWSYS_NAMESPACE=cmsys"
		]
	}
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			"Source"->MakeAbsolute(),
			"Source/kwsys"->MakeAbsolute()
		]
		PreprocessorDefines += [
			"KWSYS_NAMESPACE=cmsys"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Target.Group "External/cmsys"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "cmsys"
	%Group "Source"
	{
		%Group "kwsys"
		{
			%File "../../../../External/CMake/Source/kwsys/ProcessUNIX.c"
			{
				Compile.Type "C"
				Compile.PreprocessorDefines += [
					"KWSYS_C_HAS_CLOCK_GETTIME_MONOTONIC",
					"KWSYS_C_HAS_PTRDIFF_T",
					"KWSYS_C_HAS_SSIZE_T"
				]
			}
			%File "../../../../External/CMake/Source/kwsys/Base64.c"
			{
				Compile.Type "C"
			}
			%File "../../../../External/CMake/Source/kwsys/EncodingC.c"
			{
				Compile.Type "C"
				Compile.PreprocessorDefines += [
					"KWSYS_ENCODING_DEFAULT_CODEPAGE=CP_UTF8"
				]
			}
			%File "../../../../External/CMake/Source/kwsys/MD5.c"
			{
				Compile.Type "C"
			}
			%File "../../../../External/CMake/Source/kwsys/Terminal.c"
			{
				Compile.Type "C"
			}
			%File "../../../../External/CMake/Source/kwsys/System.c"
			{
				Compile.Type "C"
				Compile.PreprocessorDefines += [
					"KWSYS_C_HAS_CLOCK_GETTIME_MONOTONIC",
					"KWSYS_C_HAS_PTRDIFF_T",
					"KWSYS_C_HAS_SSIZE_T"
				]
			}
			%File "../../../../External/CMake/Source/kwsys/String.c"
			{
				Compile.Type "C"
				Compile.PreprocessorDefines += [
					"KWSYS_STRING_C"
				]
			}
			%File "../../../../External/CMake/Source/kwsys/Directory.cxx"
			{
				Compile.Type "C++"
			}
			%File "../../../../External/CMake/Source/kwsys/DynamicLoader.cxx"
			{
				Compile.Type "C++"
				Compile.PreprocessorDefines += [
					"KWSYS_SUPPORTS_SHARED_LIBS=1"
				]
			}
			%File "../../../../External/CMake/Source/kwsys/EncodingCXX.cxx"
			{
				Compile.Type "C++"
				Compile.PreprocessorDefines += [
					"KWSYS_ENCODING_DEFAULT_CODEPAGE=CP_UTF8"
				]
			}
			%File "../../../../External/CMake/Source/kwsys/Glob.cxx"
			{
				Compile.Type "C++"
			}
			%File "../../../../External/CMake/Source/kwsys/RegularExpression.cxx"
			{
				Compile.Type "C++"
			}
			%File "../../../../External/CMake/Source/kwsys/SystemTools.cxx"
			{
				Compile.Type "C++"
				Compile.PreprocessorDefines += [
					"KWSYS_CXX_HAS_ENVIRON_IN_STDLIB_H=0",
					"KWSYS_CXX_HAS_SETENV=1",
					"KWSYS_CXX_HAS_UNSETENV=1",
					"KWSYS_CXX_HAS_UTIMENSAT=1",
					"KWSYS_CXX_HAS_UTIMES=1",
					"KWSYS_CXX_STAT_HAS_ST_MTIM=1",
					"KWSYS_CXX_STAT_HAS_ST_MTIMESPEC=0"
				]
			}
			%File "../../../../External/CMake/Source/kwsys/CommandLineArguments.cxx"
			{
				Compile.Type "C++"
			}
			%File "../../../../External/CMake/Source/kwsys/FStream.cxx"
			{
				Compile.Type "C++"
			}
			%File "../../../../External/CMake/Source/kwsys/SystemInformation.cxx"
			{
				Compile.Type "C++"
				Compile.PreprocessorDefines += [
					"KWSYS_CXX_HAS_GETLOADAVG=1",
					"KWSYS_CXX_HAS_RLIMIT64=1",
					"KWSYS_SYSTEMINFORMATION_HAS_BACKTRACE=1",
					"KWSYS_SYSTEMINFORMATION_HAS_CPP_DEMANGLE=1",
					"KWSYS_SYSTEMINFORMATION_HAS_SYMBOL_LOOKUP=1",
					"KWSYS_SYS_HAS_IFADDRS_H=1",
					"SIZEOF_VOID_P=8"
				]
			}
		}
	}
