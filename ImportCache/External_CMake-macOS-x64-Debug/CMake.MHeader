%Target "Lib_libarchive_cmlibarchive"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities/cmlibarchive/libarchive`->MakeAbsolute(),
			`@('.'->MakeAbsolute())/Utilities/cmlibarchive`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('.'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities/cmbzip2`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/api`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities/cmzstd`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities/std`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/zlib`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"HAVE_CONFIG_H",
			"LZMA_API_STATIC"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/libarchive"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "libarchive_cmlibarchive"
	Target.BaseFileName "cmlibarchive"
