Property.CMakeOutputPath_CURL define string = "../.."->MakeAbsolute()
%Target "Exe_curltest"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			"../../Utilities"->MakeAbsolute(),
			"../../../../../../External/CMake/Utilities/cmcurl/include"->MakeAbsolute(),
			"../../../../../../External/CMake/Utilities/cmnghttp2/lib/includes"->MakeAbsolute(),
			"../../../../../../External/CMake/Utilities/std"->MakeAbsolute(),
			"../../../../../../External/CMake/Utilities"->MakeAbsolute()
		]
		PreprocessorDefines += [
			"CURL_STATICLIB",
			"HAVE_CONFIG_H"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "ConsoleExecutable"
	Target.BaseName "curltest"
	%Group "Utilities"
	{
		%File "../../../../../../External/CMake/Utilities/cmcurl/curltest.c"
		{
			Compile.Type "C"
		}
	}
	%Dependency "Lib_cmnghttp2"
	%Dependency "Lib_cmcurl"
	%Dependency "Lib_cmzlib"
}
%Target "Lib_cmcurl"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			"../../Utilities"->MakeAbsolute(),
			"../../../../../../External/CMake/Utilities/cmcurl/include"->MakeAbsolute(),
			"../../../../../../External/CMake/Utilities/cmnghttp2/lib/includes"->MakeAbsolute(),
			"../../Utilities/cmcurl/include"->MakeAbsolute(),
			"../../../../../../External/CMake/Utilities/cmcurl"->MakeAbsolute(),
			"../../Utilities/cmcurl"->MakeAbsolute(),
			"../../../../../../External/CMake/Utilities/cmcurl/lib"->MakeAbsolute(),
			"../../Utilities/cmcurl/lib"->MakeAbsolute(),
			"../../../../../../External/CMake/Utilities/std"->MakeAbsolute(),
			"../../../../../../External/CMake/Utilities"->MakeAbsolute()
		]
		PreprocessorDefines += [
			"BUILDING_LIBCURL",
			"HAVE_CONFIG_H",
			"NGHTTP2_STATICLIB"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
