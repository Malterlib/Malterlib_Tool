{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/CMake"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "CMake_test_clean"
	Target.BaseFileName "test_clean"
	%Group "macOS"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "Tests"
				{
					%Group "CMakeFiles"
					{
						%File `@('.'->MakeAbsolute())/Tests/CMakeFiles/test_clean.rule`
						{
							Compile
							{
								Type "Custom"
								Custom_CommandLine `MToolCMake -P @(`@('.'->MakeAbsolute())/Tests/test_clean.cmake`->MakeAbsolute()->EscapeHost())`
								AllowNonExisting true
								Disabled false
								Custom_WorkingDirectory `@('.'->MakeAbsolute())/Tests`->MakeAbsolute()
								Custom_Outputs []
								Custom_Inputs []
							}
						}
					}
				}
			}
		}
	}
}
