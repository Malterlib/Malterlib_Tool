						%File "Source/cmsys/Encoding.hxx"
						{
							Compile.Type None
						}
						%File "Source/cmsys/Glob.hxx"
						{
							Compile.Type None
						}
						%File "Source/cmsys/RegularExpression.hxx"
						{
							Compile.Type None
						}
						%File "Source/cmsys/SystemTools.hxx"
						{
							Compile.Type None
						}
						%File "Source/cmsys/CommandLineArguments.hxx"
						{
							Compile.Type None
						}
						%File "Source/cmsys/IOStream.hxx"
						{
							Compile.Type None
						}
						%File "Source/cmsys/FStream.hxx"
						{
