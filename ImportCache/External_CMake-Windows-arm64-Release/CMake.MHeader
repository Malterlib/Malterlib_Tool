Property.CMakeOutputPath_CMake: string = `@('.'->MakeAbsolute())`->MakeAbsolute()
%Target "Tool_CMake_Experimental"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/CMake"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "CMake_Experimental"
	Target.BaseFileName "Experimental"
	%Group "Windows"
	{
		%Group "arm64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "CMakeFiles"
				{
					%File `@('.'->MakeAbsolute())/CMakeFiles/Experimental.rule`
					{
						Compile
						{
							Type "Custom"
							Custom_CommandLine `@(`@('../../../..'->MakeAbsolute())/BuildSystem/SafeMib/Binaries/ctest.exe`->MakeAbsolute()->EscapeHost()) -D Experimental`
							AllowNonExisting true
							Disabled false
							Custom_WorkingDirectory `@('.'->MakeAbsolute())`->MakeAbsolute()
							Custom_Outputs []
							Custom_Inputs []
						}
					}
				}
			}
		}
	}
}
