Property.CMakeOutputPath_librhash "@('../..'->MakeAbsolute())"
%Target Lib_cmlibrhash
{
	Compile
	{
		!!Compile.Type C
		SearchPath "@('../../Utilities'->MakeAbsolute());@('../../../../../../External/CMake/Utilities'->MakeAbsolute());@('../../Source'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "_CRT_NONSTDC_NO_DEPRECATE;_CRT_SECURE_NO_DEPRECATE;@(Compile.PreprocessorDefines)"
	}
	Property.MalterlibTargetNameType Normal
	Target.Group "External/librhash"
	{
		!!Target.Group ""
	}
	Target.Type StaticLibrary
	Target.BaseName cmlibrhash
	%Group Utilities
	{
		%Group librhash
		{
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/algorithms.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/algorithms.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/byte_order.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/byte_order.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/hex.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/hex.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/md5.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/md5.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/rhash.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/rhash.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/sha1.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/sha1.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/sha256.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/sha256.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/sha3.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/sha3.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/sha512.c"
			{
				Compile.Type C
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/sha512.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/ustd.h"
			{
				Compile.Type None
			}
			%File "../../../../../../External/CMake/Utilities/cmlibrhash/librhash/util.h"
			{
				Compile.Type None
			}
		}
	}
}
