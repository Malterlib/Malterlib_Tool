%Target "Lib_CMake_cmnghttp2"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('.'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('.'->MakeAbsolute())/Utilities/cmnghttp2`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities/cmnghttp2/lib/includes`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities/std`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"HAVE_CONFIG_H",
			"NGHTTP2_STATICLIB"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/CMake"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "CMake_cmnghttp2"
	Target.BaseFileName "cmnghttp2"
	%Group "Utilities"
	{
		%Group "lib"
		{
			%File `@('../../../../External/CMake'->MakeAbsolute())/Utilities/cmnghttp2/lib/nghttp2_buf.c`
			{
				Compile.Type "C"
			}
