%Target "Lib_cmlibarchive"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			"../../../../External/CMake/Utilities/cmlibarchive/libarchive"->MakeAbsolute(),
			"Utilities/cmlibarchive"->MakeAbsolute(),
			"Utilities"->MakeAbsolute(),
			"../../../../External/CMake/Utilities/cmbzip2"->MakeAbsolute(),
			"../../../../External/CMake/Utilities/cmzstd"->MakeAbsolute(),
			"../../../../External/CMake/Utilities/std"->MakeAbsolute(),
			"../../../../External/CMake/Utilities"->MakeAbsolute()
		]
		PreprocessorDefines += [
			"HAVE_CONFIG_H",
			"LIBARCHIVE_STATIC"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Target.Group "External/libarchive"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "cmlibarchive"
