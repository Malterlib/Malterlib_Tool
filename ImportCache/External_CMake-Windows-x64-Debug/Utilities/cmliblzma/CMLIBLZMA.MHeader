					}
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/common/vli_size.c`
					{
						Compile.Type "C"
					}
				}
				%Group "delta"
				{
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/delta/delta_common.c`
					{
						Compile.Type "C"
					}
