Property.CMakeOutputPath_CMLIBLZMA define string = `@('../..'->MakeAbsolute())`->MakeAbsolute()
%Target "Lib_CMLIBLZMA_cmliblzma"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../..'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/common`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/api`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/check`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/common`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/delta`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/lz`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/lzma`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/rangecoder`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/simple`->MakeAbsolute(),
			`@('../..'->MakeAbsolute())/Utilities/cmliblzma`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/std`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"_CRT_NONSTDC_NO_DEPRECATE",
			"_CRT_SECURE_NO_DEPRECATE"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/CMLIBLZMA"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "CMLIBLZMA_cmliblzma"
	Target.BaseFileName "cmliblzma"
	%Group "Utilities"
	{
		%Group "cmliblzma"
		{
			%Group "common"
			{
				%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/common/sysdefs.h`
				{
					Compile.Disabled true
				}
				%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/common/tuklib_integer.h`
				{
					Compile.Disabled true
				}
			}
			%Group "liblzma"
			{
				%Group "check"
				{
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/check/check.c`
					{
						Compile.Type "C"
					}
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/check/crc32_fast.c`
					{
						Compile.Type "C"
					}
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/check/crc32_table.c`
					{
						Compile.Type "C"
					}
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/check/crc64_fast.c`
