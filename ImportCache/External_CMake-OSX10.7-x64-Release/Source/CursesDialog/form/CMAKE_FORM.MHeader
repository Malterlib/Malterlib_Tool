Property.CMakeOutputPath_CMAKE_FORM define string = "../../.."->MakeAbsolute()
%Target "Lib_cmForm"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			"../../../Utilities"->MakeAbsolute(),
			"../../../Source/CursesDialog/form"->MakeAbsolute(),
			"../../../../../../../External/CMake/Source/CursesDialog/form"->MakeAbsolute(),
			"../../../../../../../External/CMake/Utilities/std"->MakeAbsolute(),
			"../../../../../../../External/CMake/Utilities"->MakeAbsolute()
		]
		PreprocessorDefines += [
			"LIBARCHIVE_STATIC"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Target.Group "External/CMAKE_FORM"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "cmForm"
