		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "Utilities"
				{
					%Group "cmcurl"
					{
						%Group "lib"
						{
							%File "Utilities/cmcurl/lib/curl_config.h"
							{
								Compile.Type "None"
							}
						}
					}
				}
			}
		}
	}
	%Dependency "Lib_cmnghttp2"
	{
		Dependency.Indirect true
	}
	%Dependency "Lib_cmzlib"
	{
		Dependency.Indirect true
	}
}
