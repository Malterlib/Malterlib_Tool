					}
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/check/crc64_table.c`
					{
						Compile.Type "C"
					}
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/check/sha256.c`
					{
						Compile.Type "C"
					}
				}
				%Group "common"
				{
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/common/alone_decoder.c`
					{
						Compile.Type "C"
					}
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/common/alone_encoder.c`
					{
