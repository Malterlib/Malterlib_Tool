					}
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/common/filter_flags_encoder.c`
					{
						Compile.Type "C"
					}
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/common/index.c`
					{
						Compile.Type "C"
					}
					%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmliblzma/liblzma/common/index_decoder.c`
