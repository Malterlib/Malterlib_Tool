%Target "Lib_CMake_CTestLib"
{
	Compile
	{
		!!Compile.Type "C++"
		SearchPath += [
			`@('.'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Source/CTest`->MakeAbsolute(),
			`@('.'->MakeAbsolute())/Source`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Source`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Source/LexerParser`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities/std`->MakeAbsolute(),
			`@('../../../../External/CMake'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@('../../../..'->MakeAbsolute())/External/zlib`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"CURL_STATICLIB",
			"LIBARCHIVE_STATIC"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/CMake"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "CMake_CTestLib"
	Target.BaseFileName "CTestLib"
	%Group "Source"
	{
		%File `@('../../../../External/CMake'->MakeAbsolute())/Source/cmCTest.cxx`
		{
			Compile.Type "C++"
		}
		%Group "CTest"
		{
			%File `@('../../../../External/CMake'->MakeAbsolute())/Source/CTest/cmProcess.cxx`
			{
				Compile.Type "C++"
			}
			%File `@('../../../../External/CMake'->MakeAbsolute())/Source/CTest/cmCTestBinPacker.cxx`
			{
				Compile.Type "C++"
			}
			%File `@('../../../../External/CMake'->MakeAbsolute())/Source/CTest/cmCTestBuildAndTestHandler.cxx`
			{
				Compile.Type "C++"
			}
			%File `@('../../../../External/CMake'->MakeAbsolute())/Source/CTest/cmCTestBuildCommand.cxx`
			{
				Compile.Type "C++"
			}
			%File `@('../../../../External/CMake'->MakeAbsolute())/Source/CTest/cmCTestBuildHandler.cxx`
			{
				Compile.Type "C++"
			}
			%File `@('../../../../External/CMake'->MakeAbsolute())/Source/CTest/cmCTestConfigureCommand.cxx`
			{
				Compile.Type "C++"
			}
			%File `@('../../../../External/CMake'->MakeAbsolute())/Source/CTest/cmCTestConfigureHandler.cxx`
			{
				Compile.Type "C++"
			}
			%File `@('../../../../External/CMake'->MakeAbsolute())/Source/CTest/cmCTestCoverageCommand.cxx`
			{
				Compile.Type "C++"
			}
			%File `@('../../../../External/CMake'->MakeAbsolute())/Source/CTest/cmCTestCoverageHandler.cxx`
			{
				Compile.Type "C++"
			}
			%File `@('../../../../External/CMake'->MakeAbsolute())/Source/CTest/cmCTestCurl.cxx`
			{
				Compile.Type "C++"
			}
