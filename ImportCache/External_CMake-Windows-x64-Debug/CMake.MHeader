%Target Exe_curltest
{
	Compile
	{
		!!Compile.Type C
		SearchPath "@('Utilities'->MakeAbsolute());@('../../../../External/CMake/Utilities'->MakeAbsolute());@('Utilities/cmcurl/include/curl'->MakeAbsolute());@('../../../../External/CMake/Utilities/cmcurl/include'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "CURL_STATICLIB;HAVE_CONFIG_H;_CRT_NONSTDC_NO_DEPRECATE;_CRT_SECURE_NO_DEPRECATE;_WIN32_WINNT=0x0600;@(Compile.PreprocessorDefines)"
	}
	Property.MalterlibTargetNameType Normal
	Target.Group "External/CURL"
	Target.Type ConsoleExecutable
	Target.BaseName curltest
	%Group Utilities
	{
		%File "../../../../External/CMake/Utilities/cmcurl/curltest.c"
		{
			Compile.Type C
		}
	}
	%Dependency Lib_cmcurl
	%Dependency Lib_cmzlib
}
