Property.CMakeOutputPath_ninja: string = `@('.'->MakeAbsolute())`->MakeAbsolute()
%Target "Lib_ninja_libninja-re2c"
{
	Compile
	{
		!!Compile.Type "C++"
		SearchPath += [
			`@('../../../../External/ninja'->MakeAbsolute())/src`->MakeAbsolute()
		]
		PreprocessorDefines += []
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/ninja"
	{
		!!Target.Group undefined
	}
	Target.Type "StaticLibrary"
	Target.BaseName "ninja_libninja-re2c"
	Target.BaseFileName "libninja-re2c"
	Target.ObjectLibrary true
	%Group "src"
	{
		%File `@('../../../../External/ninja'->MakeAbsolute())/src/depfile_parser.cc`
		{
			Compile.Type "C++"
		}
		%File `@('../../../../External/ninja'->MakeAbsolute())/src/lexer.cc`
		{
			Compile.Type "C++"
		}
	}
}
