Property.CMakeOutputPath_cmsys "@('../..'->MakeAbsolute())"
%Target "Exe_cmsysTestProcess"
{
	Target.CLanguage "GNU11"
	Compile
	{
		!!Compile.Type "C"
		SearchPath "@('../../Source'->MakeAbsolute());@('../../Source/kwsys'->MakeAbsolute());@(Compile.SearchPath)"
		PreprocessorDefines "KWSYS_NAMESPACE=cmsys;NDEBUG;@(Compile.PreprocessorDefines)"
		CLanguage "GNU11"
	}
	Property.MalterlibTargetNameType "Normal"
	Target.Group "External/cmsys"
	{
		!!Target.Group ""
	}
	Target.Type "ConsoleExecutable"
	Target.BaseName "cmsysTestProcess"
	%Group "Source"
	{
		%File "../../../../../../External/CMake/Source/kwsys/testProcess.c"
		{
			Compile.Type "C"
		}
	}
	%Dependency "Lib_cmsys_c"
}
