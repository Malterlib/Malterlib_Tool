Property.CMakeOutputPath_CURL define string = `@('../..'->MakeAbsolute())`->MakeAbsolute()
%Target "Com_CURL_curltest"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../..'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmcurl/include`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmnghttp2/lib/includes`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/std`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"CURL_STATICLIB",
			"HAVE_CONFIG_H",
			"_CRT_NONSTDC_NO_DEPRECATE",
			"_CRT_SECURE_NO_DEPRECATE"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/CURL"
	{
		!!Target.Group undefined
	}
	Target.Type "ConsoleExecutable"
	Target.BaseName "CURL_curltest"
	Target.BaseFileName "curltest"
	%Group "Utilities"
	{
		%File `@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmcurl/curltest.c`
		{
			Compile.Type "C"
		}
	}
	%Dependency "Lib_CURL_cmcurl"
	%Dependency "Lib_CMake_cmnghttp2"
	%Dependency "Lib_CMZLIB_cmzlib"
}
%Target "Lib_CURL_cmcurl"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../..'->MakeAbsolute())/Utilities`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmcurl/include`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmnghttp2/lib/includes`->MakeAbsolute(),
			`@('../..'->MakeAbsolute())/Utilities/cmcurl/include`->MakeAbsolute(),
			`@(CMakeIntermediateDirectory)/External_CMake`->MakeAbsolute(),
			`@('../../../../../../External/CMake'->MakeAbsolute())/Utilities/cmcurl`->MakeAbsolute(),
			`@('../..'->MakeAbsolute())/Utilities/cmcurl`->MakeAbsolute(),
